// Tell Prisma to generate a JavaScript/TypeScript client we can import in our code.
generator client {
  provider = "prisma-client-js"
}

// Tell Prisma we're using Postgres and where to find it.
// DATABASE_URL is read from the .env file at runtime — never hard-coded here.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Represents a signed-in user. Created automatically by NextAuth when someone
// first signs in with Google.
model User {
  id             String    @id @default(cuid()) // primary key, auto-generated unique ID
  email          String    @unique              // Google account email, must be unique
  emailVerified  DateTime?                      // required by @auth/prisma-adapter; set by NextAuth on first sign-in
  name           String?                        // display name from Google (optional)
  image          String?                        // avatar URL from Google (optional)
  googleId       String?   @unique             // Google's own user ID, stored for reference
  favoriteMovie String?                        // null means the user hasn't completed onboarding yet
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt           // automatically updated on every write

  // Relations — one user can have many facts, OAuth accounts, and sessions
  facts         Fact[]
  accounts      Account[]
  sessions      Session[]
}

// A fun fact generated by OpenAI about a user's favorite movie.
// We snapshot the movie title at generation time so historical facts stay
// accurate even if the user later changes their favorite movie.
model Fact {
  id        String   @id @default(cuid())
  userId    String                           // foreign key linking this fact to its owner
  movie     String                           // movie title at the time this fact was generated
  content   String                           // the actual fun-fact text from OpenAI
  createdAt DateTime @default(now())

  // Cascade delete: if the user is deleted, their facts are deleted too
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Composite index so the query "latest fact for this user" is fast
  // (GET /api/fact runs: findFirst where userId, orderBy createdAt desc)
  @@index([userId, createdAt])
}

// Stores the OAuth token data for each provider a user has connected.
// Managed entirely by the NextAuth Prisma adapter — we never write to this directly.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String                   // e.g. "oauth"
  provider          String                   // e.g. "google"
  providerAccountId String                   // the user's ID on the provider's side
  refresh_token     String? @db.Text         // @db.Text = unlimited length in Postgres
  access_token      String? @db.Text
  expires_at        Int?                     // Unix timestamp when the access token expires
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // A user can only have one account per provider
  @@unique([provider, providerAccountId])
}

// Tracks active login sessions (the cookie NextAuth sets in the browser maps here).
// Also managed entirely by the NextAuth adapter.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique              // the value stored in the browser cookie
  userId       String
  expires      DateTime                      // when this session becomes invalid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Used by NextAuth for passwordless email login flows (not used in this app,
// but the adapter requires this model to exist in the schema).
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
